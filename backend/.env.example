DATABASE_URL="file:./dev.db"
PORT=4000
CORS_ORIGIN="*"

# mock = deterministic local demo, no API key required
# groq = Groq OpenAI-compatible API
# openai = OpenAI API
LLM_PROVIDER="mock"

# Groq setup: set LLM_PROVIDER="groq" and paste your key.
GROQ_API_KEY=""
GROQ_BASE_URL="https://api.groq.com/v1"
GROQ_MODEL="llama-3.1-8b-instant"

# OpenAI-compatible setup. Keep this for OpenAI or any compatible provider.
OPENAI_API_KEY=""
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_MODEL="gpt-4o-mini"

LLM_TIMEOUT_MS=30000
